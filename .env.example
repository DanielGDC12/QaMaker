# ── Banco de dados (Neon) ────────────────────────────────────
# Connection string da branch Neon (use o pooler em produção).
# Ex.: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ── Autenticação (Auth.js v5 + Google OAuth) — Parte 3 ───────
# Gerar com: openssl rand -base64 32
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Storage de imagens (Vercel Blob) — Parte 5 ──────────────
BLOB_READ_WRITE_TOKEN=

# ── Acesso externo (link compartilhado, sem login) ──────────
# Segredo HMAC que assina o cookie de sessão do convidado externo.
# Separado do AUTH_SECRET (domínios de confiança distintos).
# Gerar com: openssl rand -base64 32
EXTERNAL_SHARE_COOKIE_SECRET=
